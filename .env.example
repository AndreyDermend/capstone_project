# ---------------------------------------------------------------------------
# LexiAgent environment configuration
# Copy this file to .env and adjust values for your deployment.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# LLM provider selection
#   "ollama"    — local inference via host Ollama (default, private)
#   "anthropic" — Claude API (requires ANTHROPIC_API_KEY below)
# ---------------------------------------------------------------------------
LLM_PROVIDER=ollama

# URL the LexiAgent container uses to reach Ollama.
# - If you run Ollama natively on the host (SSH server default): host.docker.internal
# - If you run Ollama as a container in docker-compose: http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Ollama model names (must already be pulled on the host Ollama)
EXTRACTION_MODEL=qwen3:4b
EMBED_MODEL=nomic-embed-text

# Anthropic (Claude) settings — only used when LLM_PROVIDER=anthropic.
# Embeddings always use Ollama (Claude has no embedding endpoint); keep
# nomic-embed-text pulled even in Claude mode.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Port exposed by the LexiAgent API inside the container network.
API_PORT=8001

# Optional: enable bearer-token auth on /v1/* routes.
# Leave empty to keep the API open (recommended only on trusted internal networks).
LEXIAGENT_API_KEY=
